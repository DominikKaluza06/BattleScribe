<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Character">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="0dp"
        android:layout_height="241dp"
        android:background="#333333"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="128dp"
        android:layout_height="136dp"
        android:layout_marginStart="24dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="Character Avatar"
        app:layout_constraintBottom_toBottomOf="@+id/imageView2"
        app:layout_constraintStart_toStartOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.495" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="54dp"
        android:layout_height="30dp"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="12dp"
        android:text="STR:"
        android:textColor="#FBFAFA"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textView3"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:layout_constraintTop_toTopOf="@+id/imageView2"
        app:layout_constraintVertical_bias="0.926" />

    <TextView
        android:id="@+id/STR"
        android:layout_width="70dp"
        android:layout_height="27dp"
        android:layout_marginStart="12dp"
        android:text="0"
        android:textColor="#FBFAFA"
        android:textSize="20sp"
        app:layout_constraintBaseline_toBaselineOf="@+id/textView"
        app:layout_constraintStart_toEndOf="@+id/textView" />

    <TextView
        android:id="@+id/DEF"
        android:layout_width="70dp"
        android:layout_height="27dp"
        android:text="0"
        android:textColor="#FBFAFA"
        android:textSize="20sp"
        app:layout_constraintBaseline_toBaselineOf="@+id/textView3"
        app:layout_constraintEnd_toEndOf="@+id/STR"
        app:layout_constraintStart_toStartOf="@+id/STR" />

    <TextView
        android:id="@+id/MGC"
        android:layout_width="70dp"
        android:layout_height="27dp"
        android:text="0"
        android:textColor="#FBFAFA"
        android:textSize="20sp"
        app:layout_constraintBaseline_toBaselineOf="@+id/MGCtext"
        app:layout_constraintEnd_toEndOf="@+id/DEF"
        app:layout_constraintStart_toStartOf="@+id/DEF" />

    <TextView
        android:id="@+id/AGI"
        android:layout_width="70dp"
        android:layout_height="27dp"
        android:text="0"
        android:textColor="#FBFAFA"
        android:textSize="20sp"
        app:layout_constraintBaseline_toBaselineOf="@+id/AGItext"
        app:layout_constraintEnd_toEndOf="@+id/MGC"
        app:layout_constraintStart_toStartOf="@+id/MGC" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="54dp"
        android:layout_height="30dp"
        android:layout_marginTop="85dp"
        android:layout_marginBottom="12dp"
        android:text="DEF:"
        android:textColor="#FBFAFA"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/MGCtext"
        app:layout_constraintEnd_toEndOf="@+id/textView"
        app:layout_constraintStart_toStartOf="@+id/textView"
        app:layout_constraintTop_toTopOf="@+id/imageView2" />

    <TextView
        android:id="@+id/MGCtext"
        android:layout_width="54dp"
        android:layout_height="30dp"
        android:layout_marginTop="127dp"
        android:layout_marginBottom="12dp"
        android:text="MGC:"
        android:textColor="#FBFAFA"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/AGItext"
        app:layout_constraintEnd_toEndOf="@+id/textView3"
        app:layout_constraintStart_toStartOf="@+id/textView3"
        app:layout_constraintTop_toTopOf="@+id/imageView2" />

    <TextView
        android:id="@+id/AGItext"
        android:layout_width="54dp"
        android:layout_height="30dp"
        android:layout_marginTop="169dp"
        android:text="AGI:"
        android:textColor="#FBFAFA"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="@+id/MGCtext"
        app:layout_constraintStart_toStartOf="@+id/MGCtext"
        app:layout_constraintTop_toTopOf="@+id/imageView2" />

    <ImageButton
        android:id="@+id/STRbtn"
        android:layout_width="31dp"
        android:layout_height="27dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="39dp"
        android:contentDescription="Increase Strength"
        android:onClick="increaseStr"
        app:layout_constraintBottom_toBottomOf="@+id/STR"
        app:layout_constraintStart_toEndOf="@+id/STR"
        app:layout_constraintTop_toTopOf="@+id/imageView2"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@android:drawable/ic_media_play" />

    <ImageButton
        android:id="@+id/DEFbtn"
        android:layout_width="31dp"
        android:layout_height="27dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="85dp"
        android:contentDescription="Increase Defense"
        android:onClick="increaseDef"
        app:layout_constraintBottom_toBottomOf="@+id/DEF"
        app:layout_constraintStart_toEndOf="@+id/DEF"
        app:layout_constraintTop_toTopOf="@+id/imageView2"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@android:drawable/ic_media_play" />

    <ImageButton
        android:id="@+id/MGCbtn"
        android:layout_width="31dp"
        android:layout_height="27dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="127dp"
        android:contentDescription="Increase Magic"
        android:onClick="increaseMgc"
        app:layout_constraintBottom_toBottomOf="@+id/MGC"
        app:layout_constraintStart_toEndOf="@+id/MGC"
        app:layout_constraintTop_toTopOf="@+id/imageView2"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@android:drawable/ic_media_play" />

    <ImageButton
        android:id="@+id/AGIbtn"
        android:layout_width="31dp"
        android:layout_height="27dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="169dp"
        android:contentDescription="Increase Agility"
        android:onClick="increaseAgi"
        app:layout_constraintBottom_toBottomOf="@+id/AGI"
        app:layout_constraintStart_toEndOf="@+id/AGI"
        app:layout_constraintTop_toTopOf="@+id/imageView2"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@android:drawable/ic_media_play" />

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="0dp"
        android:layout_height="144dp"
        android:layout_marginTop="241dp"
        android:layout_marginBottom="346dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@drawable/ic_launcher_background" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:text="EQUIPMENT:"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView2" />

    <ImageView
        android:id="@+id/weapon_slot"
        android:layout_width="55dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        app:layout_constraintEnd_toStartOf="@+id/helmet_slot"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        tools:srcCompat="@tools:sample/avatars" />

    <ImageView
        android:id="@+id/helmet_slot"
        android:layout_width="55dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        tools:srcCompat="@tools:sample/avatars"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        app:layout_constraintStart_toEndOf="@+id/weapon_slot"
        app:layout_constraintEnd_toStartOf="@+id/armor_slot" />

    <ImageView
        android:id="@+id/armor_slot"
        android:layout_width="55dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        tools:srcCompat="@tools:sample/avatars"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        app:layout_constraintStart_toEndOf="@+id/helmet_slot"
        app:layout_constraintEnd_toStartOf="@+id/boots_slot" />

    <ImageView
        android:id="@+id/boots_slot"
        android:layout_width="55dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        tools:srcCompat="@tools:sample/avatars"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        app:layout_constraintStart_toEndOf="@+id/armor_slot"
        app:layout_constraintEnd_toStartOf="@+id/imageView12" />

    <ImageView
        android:id="@+id/imageView12"
        android:layout_width="55dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        tools:srcCompat="@tools:sample/avatars"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        app:layout_constraintStart_toEndOf="@+id/boots_slot"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>